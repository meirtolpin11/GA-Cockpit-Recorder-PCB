# KiCad per-user local prefs and autosaves
*.kicad_prl
_autosave-*
~*.lck

# KiCad backups and caches
*-backups/
fp-info-cache

# Generated manufacturing output from KiCad (regenerate from .kicad_pcb)
# Scoped to pcb/ so case/ design files are not affected
pcb/gerber/
pcb/gerber*/
pcb/drill/
pcb/*.gbr
pcb/*.gbl
pcb/*.gtl
pcb/*.gbs
pcb/*.gts
pcb/*.gbo
pcb/*.gto
pcb/*.gbp
pcb/*.gtp
pcb/*.gm1
pcb/*.drl

# KiCad's auto-generated 3D board export (regenerate from .kicad_pcb)
pcb/*.step
pcb/*.stl

# OS junk
.DS_Store
